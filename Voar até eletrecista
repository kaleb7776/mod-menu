local Players = game:GetService("Players")
local UserInputService = game:GetService("UserInputService")
local RunService = game:GetService("RunService")

local player = Players.LocalPlayer
if not player then return end

local loopAtivo = true
local VELOCIDADE_FIXA = 700
local utility = {}

-- 🛑 ERRO FATAL
local function erroFatal(msg)
    player:Kick("❌ ERRO:\n"..msg)
    error(msg)
end

-- 🎮 TOGGLE
UserInputService.InputBegan:Connect(function(input, processed)
    if not processed and input.KeyCode == Enum.KeyCode.F then
        loopAtivo = not loopAtivo
        warn("AutoRotas "..(loopAtivo and "ON" or "OFF"))
    end
end)

-- 🔍 VALIDAR CF
function utility.CalculatePosition(target)
    local ok, result = pcall(function()
        if typeof(target) == "Vector3" then
            return CFrame.new(target)
        elseif typeof(target) == "CFrame" then
            return target
        elseif typeof(target) == "Instance" then
            if target:IsA("Model") then
                local part = target.PrimaryPart or target:FindFirstChildWhichIsA("BasePart")
                if part then return part.CFrame end
            elseif target:IsA("BasePart") then
                return target.CFrame
            end
        end
        return CFrame.new(0,0,0)
    end)

    if not ok then erroFatal("Erro ao calcular posição") end
    return result
end

-- 🚗 ENCONTRAR VEÍCULO
function utility.findVehicle()
    local folder = workspace:FindFirstChild("CarrosSpawnados")
    if not folder then erroFatal("CarrosSpawnados não encontrado") end

    for _, v in ipairs(folder:GetChildren()) do
        local info = v:FindFirstChild("Info")
        local owner = info and info:FindFirstChild("Owner")
        if owner and owner.Value == player.Name then
            return v
        end
    end

    erroFatal("Veículo não encontrado")
end

-- 🔧 GARANTIR PRIMARY
local function ensurePrimary(model)
    if model.PrimaryPart then return model.PrimaryPart end
    local part = model:FindFirstChildWhichIsA("BasePart", true)
    if part then
        model.PrimaryPart = part
        return part
    end
    return nil
end

-- ✈️ TWEEN SEGURO
function utility.TweenModel(model, dest)
    local primary = ensurePrimary(model)
    if not primary then erroFatal("PrimaryPart inválido") end

    local start = primary.CFrame
    local dist = (start.Position - dest.Position).Magnitude

    if dist == 0 then return true end

    local duration = math.max(dist / VELOCIDADE_FIXA, 0.05)
    local startTime = tick()

    local finished = false
    local timeout = tick() + duration + 5

    local conn
    conn = RunService.Heartbeat:Connect(function()
        local ok, err = pcall(function()
            if not model or not model.Parent then
                error("Modelo destruído")
            end

            local alpha = math.clamp((tick() - startTime) / duration, 0, 1)
            local cf = start:Lerp(dest, alpha)

            model:PivotTo(cf)

            if alpha >= 1 then
                finished = true
                conn:Disconnect()
                model:PivotTo(dest)
            end
        end)

        if not ok then
            conn:Disconnect()
            erroFatal("Erro no Tween: "..tostring(err))
        end
    end)

    while not finished do
        if tick() > timeout then
            if conn then conn:Disconnect() end
            erroFatal("Timeout no movimento")
        end
        task.wait()
    end

    return true
end

-- 🚗 MOVER VEÍCULO
function utility.SetTweenVehicle(dest)
    local vehicle = utility.findVehicle()
    local targetCF = utility.CalculatePosition(dest)

    local old = {}

    for _, p in ipairs(vehicle:GetDescendants()) do
        if p:IsA("BasePart") then
            old[p] = p.CanCollide
            p.CanCollide = false
            p.AssemblyLinearVelocity = Vector3.zero
            p.AssemblyAngularVelocity = Vector3.zero
        end
    end

    local ok, err = pcall(function()
        utility.TweenModel(vehicle, targetCF)
    end)

    for part, state in pairs(old) do
        if part and part.Parent then
            part.CanCollide = state
        end
    end

    if not ok then
        erroFatal("Falha ao mover veículo: "..tostring(err))
    end

    return true
end

-- 🤖 PROMPT SEGURO
function utility.InteragirProximidades(pos)
    local locais = workspace:FindFirstChild("Construcoes")
    locais = locais and locais:FindFirstChild("LocaisRotas")

    if not locais then return end

    for _, prompt in ipairs(locais:GetDescendants()) do
        if prompt:IsA("ProximityPrompt") then
            local parent = prompt.Parent
            if parent and parent:IsA("BasePart") then
                if (parent.Position - pos).Magnitude <= 35 then
                    pcall(function()
                        if fireproximityprompt then
                            fireproximityprompt(prompt)
                        else
                            prompt:InputHoldBegin()
                            task.wait(prompt.HoldDuration + 0.1)
                            prompt:InputHoldEnd()
                        end
                    end)
                end
            end
        end
    end
end

-- 📍 PONTOS
local pontosFalsos = {
    CFrame.new(4177, 39, 2611)
}

local cframes = {
    CFrame.new(3614.98, 5.19, 1939.57)
}

-- 🚀 LOOP PRINCIPAL
task.spawn(function()
    if not loopAtivo then return end

    for i, cf in ipairs(cframes) do
        if not loopAtivo then break end

        pcall(function()
            utility.SetTweenVehicle(pontosFalsos[1])
            task.wait(1)

            if utility.SetTweenVehicle(cf) then
                utility.InteragirProximidades(cf.Position)
                print("✔ Ponto "..i.." completo")
                task.wait(2)
            end
        end)
    end

    loopAtivo = false
    warn("🏁 Rota finalizada")
end)

-- 🧹 LIMPEZA
pcall(function()
    local comp = workspace:FindFirstChild("Complementos")
    if comp then
        if comp:FindFirstChild("Aguas") then comp.Aguas:Destroy() end
        if comp:FindFirstChild("Areias") then comp.Areias:Destroy() end
    end
end)

-- 🛡️ PROTEÇÃO
local function setup()
    local char = player.Character or player.CharacterAdded:Wait()
    local hum = char:WaitForChild("Humanoid")

    hum.Jumping:Connect(function()
        if loopAtivo then
            loopAtivo = false
            warn("⛔ Parado: pulou")
        end
    end)

    task.spawn(function()
        while char.Parent do
            if loopAtivo and not hum.Sit then
                loopAtivo = false
                warn("⛔ Parado: saiu do banco")
            end
            task.wait(1)
        end
    end)
end

setup()
player.CharacterAdded:Connect(setup)
