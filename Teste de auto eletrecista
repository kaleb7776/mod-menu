-- 🛡️ INIT
if not game:IsLoaded() then game.Loaded:Wait() end

local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local VirtualInputManager = game:GetService("VirtualInputManager")

local player = Players.LocalPlayer
if not player then error("LocalPlayer não encontrado") end

-- ⚙️ CONFIG
local CONFIG = {
    VELOCIDADE_VOO = 150,
    TEMPO_MAX_VOO = 30
}

local autoFarm = true

-- 💀 KICK
local function erro(msg)
    player:Kick("❌ ERRO:\n"..msg)
    error(msg)
end

-- 🧠 BASE
local function getRoot()
    local char = player.Character or player.CharacterAdded:Wait()
    local root = char:FindFirstChild("HumanoidRootPart") or char:WaitForChild("HumanoidRootPart",5)
    if not root then erro("Sem HumanoidRootPart") end
    return root
end

-- ✈️ SEU VOO (ADAPTADO)
local function voarAte(pos)
    local root = getRoot()
    local start = tick()

    while (Vector3.new(root.Position.X,0,root.Position.Z) - Vector3.new(pos.X,0,pos.Z)).Magnitude > 3 do
        if not autoFarm then return end
        if tick() - start > CONFIG.TEMPO_MAX_VOO then erro("Timeout no voo") end

        local dt = RunService.Heartbeat:Wait()

        local dir = (Vector3.new(pos.X,0,pos.Z) - Vector3.new(root.Position.X,0,root.Position.Z)).Unit

        local novaXZ = Vector3.new(
            root.Position.X + dir.X * CONFIG.VELOCIDADE_VOO * dt,
            0,
            root.Position.Z + dir.Z * CONFIG.VELOCIDADE_VOO * dt
        )

        local rayParams = RaycastParams.new()
        rayParams.FilterDescendantsInstances = {player.Character}
        rayParams.FilterType = Enum.RaycastFilterType.Exclude

        local result = workspace:Raycast(
            Vector3.new(novaXZ.X, root.Position.Y + 50, novaXZ.Z),
            Vector3.new(0,-200,0),
            rayParams
        )

        local y = result and (result.Position.Y + 3) or root.Position.Y
        root.CFrame = CFrame.new(novaXZ.X, y, novaXZ.Z)
    end
end

-- 🔘 PROMPT
local ultimoPrompt = 0
local function usarPrompt(prompt)
    if not prompt then erro("Prompt nil") end
    if tick() - ultimoPrompt < 0.8 then return end
    ultimoPrompt = tick()

    local ok = pcall(function()
        prompt:InputHoldBegin()
        task.wait(prompt.HoldDuration + 0.1)
        prompt:InputHoldEnd()
    end)

    if fireproximityprompt then
        pcall(function()
            fireproximityprompt(prompt)
        end)
    end

    if not ok then erro("Falha ao usar prompt") end
end

-- 🔢 TECLA 1
local function apertar1()
    pcall(function()
        VirtualInputManager:SendKeyEvent(true, Enum.KeyCode.One, false, game)
        task.wait(0.1)
        VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.One, false, game)
    end)
end

-- 📍 PEGAR POSTE CERTO (SEM BUG)
local function getPoste(index)
    local pasta = workspace:WaitForChild("Complementos"):WaitForChild("Postes")
    local lista = pasta:GetChildren()

    local poste = lista[index]
    if not poste then erro("Poste "..index.." não encontrado") end

    return poste
end

-- ⚡ EXECUTAR 1 POSTE (SEQUÊNCIA EXATA)
local function fazerPoste(index, escada)
    local poste = getPoste(index)

    local prox = poste:FindFirstChild("proxymiti")
    local real = poste:FindFirstChild("Poste")

    if not prox then erro("proxymiti faltando "..index) end
    if not real then erro("Poste faltando "..index) end

    -- ESCADA
    task.wait(1)
    voarAte(escada.Position)

    task.wait(1)
    usarPrompt(escada:FindFirstChildOfClass("ProximityPrompt"))
    apertar1()

    -- PROXY
    task.wait(1)
    voarAte(prox.Position)

    task.wait(1)
    usarPrompt(prox:FindFirstChildOfClass("ProximityPrompt"))

    -- POSTE
    task.wait(1)
    voarAte(real.Position)

    task.wait(0.5)
    usarPrompt(real:FindFirstChildOfClass("ProximityPrompt"))

    -- VOLTA PROXY
    task.wait(1)
    voarAte(prox.Position)

    -- VOLTA ESCADA
    task.wait(0.5)
    voarAte(escada.Position)

    task.wait(1)
    usarPrompt(escada:FindFirstChildOfClass("ProximityPrompt"))
    apertar1()
end

-- 🔁 LOOP
task.spawn(function()

    local escada = workspace:WaitForChild("CarrosSpawnados")
        :WaitForChild("Eletricista")
        :WaitForChild("Body")
        :WaitForChild("Escada")
        :WaitForChild("Proxy")

    if not escada then erro("Escada não encontrada") end

    while autoFarm do
