            -- 🦘 PULA
            local hum = player.Character and player.Character:FindFirstChild("Humanoid")
            if hum then
                hum.Jump = true
            end

            fazerPoste(31, escada)
            task.wait(1)

            fazerPoste(32, escada)
            task.wait(1)

            fazerPoste(33, escada)

        end)

        -- ⏱️ ESPERA 5s ANTES DE RECOMEÇAR
        task.wait(5)
    end

end)
