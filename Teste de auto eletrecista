-- Auto Eletricista V12 (PERFEITO - SEM FALHAS SILENCIOSAS)

local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local VirtualInputManager = game:GetService("VirtualInputManager")
local player = Players.LocalPlayer

local autoFarm = false

local CONFIG = {
    VELOCIDADE_VOO = 150,
    TEMPO_MAX_VOO = 30
}

-- ROOT SEGURO
local function getRoot()
    local char = player.Character or player.CharacterAdded:Wait()
    local root = char:WaitForChild("HumanoidRootPart", 10)
    if not root then
        player:Kick("❌ Root não encontrado")
    end
    return root
end

-- PROMPT (ANTI BUG + GARANTIDO)
local ultimoUso = 0
local function usarPromptSeguro(obj)
    if not obj then
        player:Kick("❌ Objeto do prompt nil")
        return false
    end

    local prompt = obj:FindFirstChildOfClass("ProximityPrompt")
    if not prompt then
        player:Kick("❌ Prompt não encontrado em "..obj.Name)
        return false
    end

    if tick() - ultimoUso < 0.7 then
        task.wait(0.3)
    end
    ultimoUso = tick()

    local ok = pcall(function()
        prompt:InputHoldBegin()
        task.wait(prompt.HoldDuration + 0.1)
        prompt:InputHoldEnd()
    end)

    if fireproximityprompt then
        pcall(function()
            fireproximityprompt(prompt)
        end)
    end

    if not ok then
        player:Kick("❌ Falha ao usar prompt")
    end

    return true
end

-- TECLA 1 SEGURA
local function apertar1()
    local ok = pcall(function()
        VirtualInputManager:SendKeyEvent(true, Enum.KeyCode.One, false, game)
        task.wait(0.1)
        VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.One, false, game)
    end)

    if not ok then
        player:Kick("❌ Falha ao apertar tecla 1")
    end
end

-- VOO PERFEITO
local function voarAte(pos)
    local root = getRoot()
    local tempoInicio = tick()

    while true do
        if not autoFarm then return false end

        local dist = (Vector3.new(root.Position.X,0,root.Position.Z) - Vector3.new(pos.X,0,pos.Z)).Magnitude
        if dist <= 3 then break end

        if tick() - tempoInicio > CONFIG.TEMPO_MAX_VOO then
            player:Kick("❌ Tempo de voo excedido")
        end

        local dt = RunService.Heartbeat:Wait()
        local currentPos = root.Position

        local diff = Vector3.new(pos.X,0,pos.Z) - Vector3.new(currentPos.X,0,currentPos.Z)
        if diff.Magnitude < 0.1 then break end

        local dir = diff.Unit

        local novaXZ = Vector3.new(
            currentPos.X + dir.X * CONFIG.VELOCIDADE_VOO * dt,
            0,
            currentPos.Z + dir.Z * CONFIG.VELOCIDADE_VOO * dt
        )

        local rayParams = RaycastParams.new()
        rayParams.FilterDescendantsInstances = {player.Character}
        rayParams.FilterType = Enum.RaycastFilterType.Exclude

        local result = workspace:Raycast(
            Vector3.new(novaXZ.X, currentPos.Y + 50, novaXZ.Z),
            Vector3.new(0, -200, 0),
            rayParams
        )

        local y = result and (result.Position.Y + 3) or currentPos.Y
        root.CFrame = CFrame.new(novaXZ.X, y, novaXZ.Z)
    end

    return true
end

-- PEGAR PATHS SEGURO + ORDEM FIXA
local function getPaths()
    local escada = workspace:WaitForChild("CarrosSpawnados",10)
        :WaitForChild("Eletricista",10)
        :WaitForChild("Body",10)
        :WaitForChild("Escada",10)
        :WaitForChild("Proxy",10)

    if not escada then
        player:Kick("❌ Escada não encontrada")
    end

    local pasta = workspace:WaitForChild("Complementos",10):WaitForChild("Postes",10)
    local postes = pasta:GetChildren()

    -- ORDEM FIXA (CRÍTICO)
    table.sort(postes, function(a,b)
        return a.Name < b.Name
    end)

    if #postes < 33 then
        player:Kick("❌ Postes insuficientes")
    end

    return escada, postes
end

-- EXECUTAR POSTE (VALIDAÇÃO TOTAL)
local function fazerPoste(index, escada, postes)
    local poste = postes[index]
    if not poste then
        player:Kick("❌ Poste "..index.." não existe")
    end

    local prox = poste:FindFirstChild("proxymiti")
    local real = poste:FindFirstChild("Poste")

    if not prox or not real then
        player:Kick("❌ Estrutura do poste inválida")
    end

    task.wait(1)

    -- ESCADA
    if not voarAte(escada.Position) then return end
    task.wait(1)
    usarPromptSeguro(escada)
    apertar1()

    task.wait(1)

    -- PROXY
    if not voarAte(prox.Position) then return end
    task.wait(1)
    usarPromptSeguro(prox)

    task.wait(1)

    -- POSTE
    if not voarAte(real.Position) then return end
    task.wait(0.5)
    usarPromptSeguro(real)

    task.wait(1)

    -- VOLTA PROXY
    if not voarAte(prox.Position) then return end
    task.wait(0.5)

    -- VOLTA ESCADA
    if not voarAte(escada.Position) then return end
    task.wait(1)
    usarPromptSeguro(escada)
    apertar1()
end

-- LOOP PERFEITO
local function loop()
    local escada, postes = getPaths()

    while autoFarm do
        local ok, err = pcall(function()

            fazerPoste(31, escada, postes)
            task.wait(1)

            fazerPoste(32, escada, postes)
            task.wait(1)

            fazerPoste(33, escada, postes)

        end)

        if not ok then
            player:Kick("❌ Erro crítico: "..tostring(err))
            break
        end

        task.wait(5)
    end
end

-- TOGGLE
if AutoSection and AutoSection.AddToggle then
    AutoSection:AddToggle("Auto Eletricista V12", false, nil, function(state)
        autoFarm = state
        if state then
            task.spawn(loop)
        end
    end)
else
    autoFarm = true
    task.spawn(loop)
end
