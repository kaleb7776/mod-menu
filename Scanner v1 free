ladb_instant_mdns() {

  clear
  printf '%bLADB SEM IP (AUTOMÁTICO)%b\n' "$BOLD$CYN" "$RESET"
  line

  # =========================
  # IP AUTOMÁTICO
  # =========================
  ip="$(getprop dhcp.wlan0.ipaddress)"
[ -z "$ip" ] && ip="$(ip route get 8.8.8.8 2>/dev/null | awk '{print $7; exit}')"
[ -z "$ip" ] && ip="$(ifconfig wlan0 2>/dev/null | awk '/inet / {print $2}')"
[ -z "$ip" ] && ip="0.0.0.0"
# =========================
  # INPUT DE PAREAMENTO
  # =========================
  printf 'Porta de pareamento: '
  read -r pair_port

  printf 'Código de pareamento: '
  read -r pair_code

  adb kill-server >/dev/null 2>&1
  adb start-server >/dev/null 2>&1

  echo
  msg "Fazendo pareamento..." "$CYN"

  adb pair "$ip:$pair_port" "$pair_code"

  echo
  msg "Detectando porta ADB CONNECT..." "$CYN"

  local adb_port=""

  # =========================
  # CACHE PRIMEIRO
  # =========================
  if [ -f "$HOME/adb_last_port" ]; then
    adb_port="$(cat "$HOME/adb_last_port")"

    adb connect "$ip:$adb_port" >/dev/null 2>&1

    if ! adb devices | grep -q "$ip:$adb_port.*device"; then
      adb_port=""
    fi
  fi

  # =========================
  # SCAN DE PORTAS
  # =========================
  if [ -z "$adb_port" ]; then
    for p in 37000 37173 37491 38415 39227 40351 41729 43011 44137 45555 33507 5555; do

      out=$(adb connect "$ip:$p" 2>&1)

      if echo "$out" | grep -q "connected to"; then

        sleep 1

        if adb devices | grep -q "$ip:$p.*device"; then
          adb_port="$p"
          break
        fi
      fi
    done
  fi

  # =========================
  # FALLBACK MANUAL (GARANTIDO)
  # =========================
  if [ -z "$adb_port" ]; then
    msg "Não achei a porta automaticamente." "$YEL"
    printf 'Digite a porta do ADB CONNECT: '
    read -r adb_port
  fi

  # =========================
  # SALVAR CACHE
  # =========================
  echo "$adb_port" > "$HOME/adb_last_port"

  echo
  msg "Conectando..." "$CYN"

  # =========================
  # CONEXÃO FINAL VALIDADA
  # =========================
  adb connect "$ip:$adb_port" >/dev/null 2>&1

  sleep 1

  if adb devices | grep -q "$ip:$adb_port.*device"; then
    msg "CONECTADO COM SUCESSO" "$GRN"
    ADB_HOST="$ip:$adb_port"
  else
    msg "Falha na conexão" "$RED"
  fi

  echo
  adb devices

  pause
}

