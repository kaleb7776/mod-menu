pretty_records() {
  awk -F'|' '
  function trim(s){
    sub(/^[ \t]+/, "", s)
    sub(/[ \t]+$/, "", s)
    return s
  }

  {
    date = trim($1)
    size = trim($2)
    path = trim($3)

    if (path != "") {
      printf "• %s | %s bytes | %s\n", date, size, path
    } else {
      print "• " $0
    }
  }'
}

