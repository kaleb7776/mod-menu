list_suspicious_apps() {
  banner
  echo -e "${RED}[APPS FORA DO SISTEMA E PLAY STORE - v2]${NC}"
  echo

  # listas base
  SYS=$(adb shell pm list packages -s | sed 's/package://g')
  STORE=$(adb shell cmd package list packages -i)

  echo "$STORE" | while read -r line; do
    pkg=$(echo "$line" | sed -n 's/^package:\([^ ]*\).*/\1/p')
    inst=$(echo "$line" | sed -n 's/.*installer=\(.*\)$/\1/p')

    [ -z "$pkg" ] && continue

    # 1) pula sistema
    echo "$SYS" | grep -qx "$pkg" && continue

    # 2) pula Play Store
    [ "$inst" = "com.android.vending" ] && continue

    # 3) filtra apenas suspeitos reais
    if [ -z "$inst" ] || [ "$inst" = "null" ] || [ "$inst" = "unknown" ]; then
      echo "[EXTERNO/DESCONHECIDO] $pkg | installer=$inst"
    else
      echo "[FORA PLAY STORE] $pkg | installer=$inst"
    fi
  done

  echo
  echo -e "${YELLOW}Scan finalizado. Pressione ENTER para voltar...${NC}"
  read
}

