load_blacklist() {
  local tmp
  tmp="$(mktemp "${CACHE_BL}.XXXXXX")" || {
    echo "[❌] Não consegui criar arquivo temporário"
    exit 1
  }

  if ! curl -fsSL --retry 2 --connect-timeout 8 --max-time 20 \
    "$GITHUB_BLACKLIST" -o "$tmp"; then
    rm -f "$tmp"
    echo "[❌] Falha ao baixar blacklist"
    exit 1
  fi

  if [ ! -s "$tmp" ]; then
    rm -f "$tmp"
    echo "[❌] Blacklist vazia ou inexistente"
    exit 1
  fi

  if ! jq -e '.devices | type == "array"' "$tmp" >/dev/null 2>&1; then
    rm -f "$tmp"
    echo "[❌] Blacklist inválida"
    exit 1
  fi

  mv -f "$tmp" "$CACHE_BL"
}

