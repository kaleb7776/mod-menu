  if ! is_missing "$json_matchid" && ! is_missing "$name_matchid" && [ "$json_matchid" != "$name_matchid" ]; then
    flags="${flags:+$flags }MATCHID≠NOME"
    score=$((score + 6))
  fi

  printf '%s|%s|%s|%s|%s|%s|%s|%s|%s|%s|%s|%s|%s|%s|%s|%s|%s|%s|%s|%s|%s|%s|%s|%s|%s|%s|%s|%s\n' \
    "$score" "$flags" "$mtime" "$name_stamp" "$json_date" "$json_show" "$file_name" "$json_matchid" "$name_matchid" \
