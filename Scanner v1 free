  local flags=""

  pack="$(json_pack "$jf" || true)"

  if [ -z "$pack" ]; then
    score=10
    flags="JSON_INVÁLIDO"
    printf '%s|%s|%s|%s|%s|%s|%s|%s|%s|%s|%s|%s|%s|%s|%s|%s|%s|%s|%s|%s|%s|%s|%s|%s|%s|%s|%s|%s\n' \
      "$score" "$flags" "" "" "" "" "" "" "" "" "" "" "" "" "" "" "" "" "" "" "" "" "" "" "" "" "" ""
    return 0
  fi

 IFS='|' read -r \
mtime json_date json_show file_name json_matchid \
rank kills pc total delta gamemode matchmode version \
account mapid istemp isgen haskc \
killc deadc hsc multic epicc guarc <<< "${pack:-}"

name_matchid="$(matchid_from_name "$jf")"
name_stamp="$(extract_ff_time "$jf")"
