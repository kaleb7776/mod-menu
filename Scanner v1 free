hash_checker() {
  banner
  section "Hash Checker"

  read -r -p "Digite o caminho completo do arquivo: " file

  if [ ! -f "$file" ]; then
    error "Arquivo não encontrado."
    pause
    return
  fi

  printf '\nSHA256:\n'
  sha256sum "$file" 2>/dev/null || error "sha256sum não conseguiu ler o arquivo."

  printf '\nMD5:\n'
  md5sum "$file" 2>/dev/null || error "md5sum não conseguiu ler o arquivo."
  pause
}

