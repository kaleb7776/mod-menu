playstore_origin() {
  banner
  section "Origem de instalação do Free Fire"

  if ! adb_ready; then
    pause
    return
  fi

  local installer_line installer installer_label
  installer_line=$(adb_run "pm list packages -i | grep 'package:$PKG'" | head -n 1)
  installer=$(printf '%s' "$installer_line" | sed -n 's/.*installer=//p')

  if [ -z "$installer" ]; then
    printf 'Linha bruta          : %s\n' "$installer_line"
    warn "Não foi possível identificar o instalador."
  else
    case "$installer" in
      com.android.vending)
        installer_label="Play Store"
        ;;
      *)
        installer_label="$installer"
        ;;
    esac

    printf 'Linha bruta          : %s\n' "$installer_line"
    printf 'Instalador           : %s\n' "$installer_label"
    printf 'Interpretação        : %s\n' "$(
      [ "$installer" = "com.android.vending" ] && printf 'instalado pela Play Store (normal)' || printf 'instalado por outra origem ou método'
    )"
  fi
  pause
}

