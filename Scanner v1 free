extract_ff_time() {
  local input base ts y m d hh mm ss

  input="${1:-}"
  base="$(basename "$input")"
  ts="${base%%_*}"

  # Formato principal do Free Fire:
  # 2026-05-17-16-51-55_...
  if [[ "$ts" =~ ^([0-9]{4})-([0-9]{2})-([0-9]{2})-([0-9]{2})-([0-9]{2})-([0-9]{2})$ ]]; then
    y="${BASH_REMATCH[1]}"
    m="${BASH_REMATCH[2]}"
    d="${BASH_REMATCH[3]}"
    hh="${BASH_REMATCH[4]}"
    mm="${BASH_REMATCH[5]}"
    ss="${BASH_REMATCH[6]}"
    printf '%s-%s-%s %s:%s:%s\n' "$y" "$m" "$d" "$hh" "$mm" "$ss"
    return 0
  fi

  # Aceita também textos com data/hora no meio
  if [[ "$input" =~ ([0-9]{4})-([0-9]{2})-([0-9]{2})[[:space:]T_-]([0-9]{2})[:.-]([0-9]{2})[:.-]([0-9]{2}) ]]; then
    y="${BASH_REMATCH[1]}"
    m="${BASH_REMATCH[2]}"
    d="${BASH_REMATCH[3]}"
    hh="${BASH_REMATCH[4]}"
    mm="${BASH_REMATCH[5]}"
    ss="${BASH_REMATCH[6]}"
    printf '%s-%s-%s %s:%s:%s\n' "$y" "$m" "$d" "$hh" "$mm" "$ss"
    return 0
  fi

  printf 'N/A\n'
}

to_epoch_safe() {
  local s="$1"
  [ -z "$s" ] && echo ""
