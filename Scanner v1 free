human_secs() {
  local s="${1:-0}"
  [ "$s" -lt 0 ] && s=0
  printf '%02dm%02ds' $((s / 60)) $((s % 60))
}

progress_bar() {
  local done="${1:-0}"
  local total="${2:-1}"
  local width=24
  local filled empty pct i

  [ "$total" -le 0 ] && total=1
  pct=$((done * 100 / total))
  filled=$((pct * width / 100))
  empty=$((width - filled))

  printf '['
  for ((i=0; i<filled; i++)); do printf '='; done
  for ((i=0; i<empty; i++)); do printf '.'; done
  printf '] %3d%%' "$pct"
}


run_step() {
  local label="$1"
  shift

  local start elapsed avg remaining
  start=$SECONDS

  printf '\n%b%s%b\n' "$MAGENTA" "$label" "$NC"
  "$@"

  elapsed=$((SECONDS - start))
  STEP_DONE=$((STEP_DONE + 1))
  STEP_ELAPSED_SUM=$((STEP_ELAPSED_SUM + elapsed))

  if [ "$STEP_DONE" -gt 0 ]; then
    avg=$((STEP_ELAPSED_SUM / STEP_DONE))
  else
    avg=0
  fi

  remaining=$((avg * (STEP_TOTAL - STEP_DONE)))
  printf '  '
  progress_bar "$STEP_DONE" "$STEP_TOTAL"
  printf '  concluído em %s | faltam aprox. %s\n' "$(human_secs "$elapsed")" "$(human_secs "$remaining")"
}


