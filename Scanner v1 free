json_pack() {
  local file="$1"
  local tmp remote_mtime
  tmp="$(mktemp)"

  remote_mtime="$(adb_remote_mtime "$file" | head -n 1)"

  adb exec-out cat "$file" > "$tmp" 2>/dev/null || {
    rm -f "$tmp"
    return 1
  }

  python3 - "$tmp" "$remote_mtime" <<'PY'
import json, sys
from pathlib import Path

p = Path(sys.argv[1])
mtime = sys.argv[2].strip() if len(sys.argv) > 2 else ""

def safe(v):
    if v is None:
        return ""
    if isinstance(v, (dict, list)):
        try:
            return json.dumps(v, ensure_ascii=False, separators=(",", ":"))
        except Exception:
            return str(v)
    return str(v)

try:
    raw = p.read_bytes()
    text = raw.decode("utf-8-sig", errors="replace")
    data = json.loads(text)
except Exception:
    data = {}

def find_key(obj, keys):
    if isinstance(obj, dict):
        for k in keys:
            if k in obj and obj[k] not in (None, "", "null"):
                return obj[k]
        for v in obj.values():
            r = find_key(v, keys)
            if r not in ("", None):
                return r
    elif isinstance(obj, list):
        for item in obj:
            r = find_key(item, keys)
            if r not in ("", None):
                return r
    return ""

fields = [
    mtime,
    safe(find_key(data, ["MatchDateTime", "MatchDate", "MatchStartTime", "StartTime", "CreateTime"])),
    safe(find_key(data, ["MatchDateShowTime", "MatchShowTime", "ShowTime", "DisplayTime"])),
    safe(find_key(data, ["FileName", "Filename", "fileName"])),
    safe(find_key(data, ["MatchID", "MatchId", "matchId"])),
    safe(find_key(data, ["Rank", "rank"])),
    safe(find_key(data, ["Kill", "Kills", "kill", "kills"])),
    safe(find_key(data, ["PlayerCount", "Players", "PlayerNum", "playerCount"])),
    safe(find_key(data, ["GameTotalTime", "TotalTime", "MatchTime", "gameTotalTime"])),
    safe(find_key(data, ["RankingPointsDelta", "RankDelta", "RankingDelta"])),
    safe(find_key(data, ["GameMode", "gameMode"])),
    safe(find_key(data, ["MatchMode", "matchMode"])),
    safe(find_key(data, ["Version", "version"])),
    safe(find_key(data, ["AccountID", "accountId", "AccountId"])),
    safe(find_key(data, ["MapID", "MapId", "mapId"])),
    safe(find_key(data, ["IsTemporary", "isTemporary"])),
    safe(find_key(data, ["IsGenerated", "isGenerated"])),
    safe(find_key(data, ["HasKillCam", "hasKillCam"])),
    str(len(find_key(data, ["m_HighlightInfo", "HighlightInfo", "highlightInfo"]).get("KillEvents", [])) if isinstance(find_key(data, ["m_HighlightInfo", "HighlightInfo", "highlightInfo"]), dict) else 0),
    str(len(find_key(data, ["m_HighlightInfo", "HighlightInfo", "highlightInfo"]).get("DeadEvents", [])) if isinstance(find_key(data, ["m_HighlightInfo", "HighlightInfo", "highlightInfo"]), dict) else 0),
    str(len(find_key(data, ["m_HighlightInfo", "HighlightInfo", "highlightInfo"]).get("HeadShotHighlightEvents", [])) if isinstance(find_key(data, ["m_HighlightInfo", "HighlightInfo", "highlightInfo"]), dict) else 0),
    str(len(find_key(data, ["m_HighlightInfo", "HighlightInfo", "highlightInfo"]).get("MultiKillHighlightEvents", [])) if isinstance(find_key(data, ["m_HighlightInfo", "HighlightInfo", "highlightInfo"]), dict) else 0),
    str(len(find_key(data, ["m_HighlightInfo", "HighlightInfo", "highlightInfo"]).get("EpicHighlightEvents", [])) if isinstance(find_key(data, ["m_HighlightInfo", "HighlightInfo", "highlightInfo"]), dict) else 0),
    str(len(find_key(data, ["m_HighlightInfo", "HighlightInfo", "highlightInfo"]).get("GuaranteedEvents", [])) if isinstance(find_key(data, ["m_HighlightInfo", "HighlightInfo", "highlightInfo"]), dict) else 0),
]

print("|".join(v.replace("|", "/") for v in fields))
PY
  local rc=$?
  rm -f "$tmp"
  return $rc
}

