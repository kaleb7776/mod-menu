only_time() {
  local input="${1:-}"

  if [[ "$input" =~ ([0-9]{4})-([0-9]{2})-([0-9]{2})-([0-9]{2})-([0-9]{2})-([0-9]{2}) ]]; then
    printf '%s:%s:%s\n' "${BASH_REMATCH[4]}" "${BASH_REMATCH[5]}" "${BASH_REMATCH[6]}"
    return 0
  fi

  if [[ "$input" =~ ([0-9]{2}):([0-9]{2}):([0-9]{2}) ]]; then
    printf '%s:%s:%s\n' "${BASH_REMATCH[1]}" "${BASH_REMATCH[2]}" "${BASH_REMATCH[3]}"
    return 0
  fi

  printf 'N/A\n'
}

