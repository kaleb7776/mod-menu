  if ! adb_ready; then
    pause
    return
  fi

  local raw_tz tz device_time utc_time
  raw_tz=$(adb_run "getprop persist.sys.timezone")
  tz=$(normalize_tz "$raw_tz")
  device_time=$(adb_run "date '+%d/%m/%Y %H:%M:%S'")
  utc_time=$(date -u '+%d/%m/%Y %H:%M:%S UTC')

  printf 'Data/hora do aparelho : %s\n' "$device_time"
  printf 'Fuso horário          : %s\n' "$tz"
  printf 'Fuso bruto            : %s\n' "$raw_tz"
  printf 'Horário UTC           : %s\n' "$utc_time"
  pause
}

