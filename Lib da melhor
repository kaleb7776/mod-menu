                    Parent = Content
                })
                
                if not KeyFrame then return nil end
                
                AddCorner(KeyFrame, 6)
                
                Create("TextLabel", {
                    Name = "Label",
                    Size = UDim2.new(1, -70, 1, 0),
                    Position = UDim2.new(0, 10, 0, 0),
                    BackgroundTransparency = 1,
                    Text = text,
                    TextColor3 = Theme.Text,
                    TextSize = 12,
                    Font = Enum.Font.Gotham,
                    TextXAlignment = Enum.TextXAlignment.Left,
                    Parent = KeyFrame
                })
                
                local KeyLabel = Create("TextLabel", {
                    Name = "Key",
                    Size = UDim2.new(0, 55, 0, 22),
                    Position = UDim2.new(1, -60, 0.5, -11),
                    BackgroundColor3 = Theme.SliderBg,
                    Text = (key.Name == "None") and "..." or key.Name,
                    TextColor3 = Theme.Accent,
                    TextSize = 11,
                    Font = Enum.Font.GothamBold,
                    Parent = KeyFrame
                })
                
                if KeyLabel then
                    AddCorner(KeyLabel, 4)
                end
                
                KeyFrame.MouseButton1Click:Connect(function()
                    if listening then return end
                    listening = true
                    if KeyLabel then
                        KeyLabel.Text = "..."
                        Tween(KeyLabel, 0.15, {BackgroundColor3 = Theme.Accent})
                        KeyLabel.TextColor3 = Color3.new(1, 1, 1)
                    end
                    
                    local conn
                    conn = UserInputService.InputBegan:Connect(function(input)
                        if input.UserInputType == Enum.UserInputType.Keyboard then
                            key = input.KeyCode
                            if KeyLabel then
                                KeyLabel.Text = key.Name
                                Tween(KeyLabel, 0.15, {BackgroundColor3 = Theme.SliderBg})
                                KeyLabel.TextColor3 = Theme.Accent
                            end
                            if flag then Library.Flags[flag] = key end
                            listening = false
                            conn:Disconnect()
                        end
                    end)
                end)
                
                KeyFrame.MouseEnter:Connect(function()
                    Tween(KeyFrame, 0.15, {BackgroundColor3 = Theme.ElementHover})
                end)
                
                KeyFrame.MouseLeave:Connect(function()
                    Tween(KeyFrame, 0.15, {BackgroundColor3 = Theme.Element})
                end)
                
                -- Listen for keybind press
                UserInputService.InputBegan:Connect(function(input, gp)
                    if gp or listening then return end
                    if input.KeyCode == key then
                        pcall(callback)
                    end
                end)
                
                if flag then Library.Flags[flag] = key end
                
                local obj = {}
                function obj:Set(newKey)
                    key = newKey
                    if KeyLabel then
                        KeyLabel.Text = (key.Name == "None") and "..." or key.Name
                    end
                    if flag then Library.Flags[flag] = key end
                end
                function obj:Get()
                    return key
                end
                return obj
            end
            
            -- COLOR PICKER
            function SectionObj:AddColorPicker(text, default, flag, callback)
                text = text or "Color"
                default = default or Color3.fromRGB(255, 255, 255)
                callback = callback or function() end
                
                local h, s, v = default:ToHSV()
                local color = default
                local open = false
                
                local ColorFrame = Create("Frame", {
                    Name = "ColorPicker",
                    Size = UDim2.new(1, 0, 0, 32),
                    BackgroundTransparency = 1,
                    ClipsDescendants = false,
                    Parent = Content
                })
                
                if not ColorFrame then return nil end
                
                Create("TextLabel", {
                    Name = "Label",
                    Size = UDim2.new(1, -45, 1, 0),
                    BackgroundTransparency = 1,
                    Text = text,
                    TextColor3 = Theme.Text,
                    TextSize = 12,
                    Font = Enum.Font.Gotham,
                    TextXAlignment = Enum.TextXAlignment.Left,
                    Parent = ColorFrame
                })
                
                local ColorBtn = Create("TextButton", {
                    Name = "ColorButton",
                    Size = UDim2.new(0, 35, 0, 22),
                    Position = UDim2.new(1, -37, 0.5, -11),
                    BackgroundColor3 = color,
                    Text = "",
                    Parent = ColorFrame
                })
                
                if ColorBtn then
                    AddCorner(ColorBtn, 4)
                    AddStroke(ColorBtn, Theme.Border)
                end
                
                local Picker = Create("Frame", {
                    Name = "Picker",
                    Size = UDim2.new(1, 0, 0, 0),
                    Position = UDim2.new(0, 0, 1, 4),
                    BackgroundColor3 = Theme.Section,
                    ClipsDescendants = true,
                    Visible = false,
                    ZIndex = 30,
                    BorderSizePixel = 0,
                    Parent = ColorFrame
                })
                
                if Picker then
                    AddCorner(Picker, 8)
                    AddStroke(Picker, Theme.Border)
                end
                
                local SVMap = Create("ImageButton", {
                    Name = "SVMap",
                    Size = UDim2.new(0, 120, 0, 90),
                    Position = UDim2.new(0, 10, 0, 10),
                    BackgroundColor3 = Color3.fromHSV(h, 1, 1),
                    Image = "rbxassetid://4155801252",
                    AutoButtonColor = false,
                    ZIndex = 31,
                    Parent = Picker
                })
                
                if SVMap then
                    AddCorner(SVMap, 4)
                end
                
                local SVCursor = Create("Frame", {
                    Name = "Cursor",
                    Size = UDim2.new(0, 8, 0, 8),
                    AnchorPoint = Vector2.new(0.5, 0.5),
                    Position = UDim2.new(s, 0, 1 - v, 0),
                    BackgroundColor3 = Color3.new(1, 1, 1),
                    ZIndex = 32,
                    BorderSizePixel = 0,
                    Parent = SVMap
                })
                
                if SVCursor then
                    AddCorner(SVCursor, 4)
                    AddStroke(SVCursor, Color3.new(0, 0, 0), 1)
                end
                
                local HueBar = Create("ImageButton", {
                    Name = "HueBar",
                    Size = UDim2.new(0, 18, 0, 90),
                    Position = UDim2.new(0, 140, 0, 10),
                    BackgroundColor3 = Color3.new(1, 1, 1),
                    AutoButtonColor = false,
                    ZIndex = 31,
                    Parent = Picker
                })
                
                if HueBar then
                    AddCorner(HueBar, 4)
                    
                    Create("UIGradient", {
                        Rotation = 90,
                        Color = ColorSequence.new({
                            ColorSequenceKeypoint.new(0, Color3.fromRGB(255, 0, 0)),
                            ColorSequenceKeypoint.new(0.167, Color3.fromRGB(255, 255, 0)),
                            ColorSequenceKeypoint.new(0.333, Color3.fromRGB(0, 255, 0)),
                            ColorSequenceKeypoint.new(0.5, Color3.fromRGB(0, 255, 255)),
                            ColorSequenceKeypoint.new(0.667, Color3.fromRGB(0, 0, 255)),
                            ColorSequenceKeypoint.new(0.833, Color3.fromRGB(255, 0, 255)),
                            ColorSequenceKeypoint.new(1, Color3.fromRGB(255, 0, 0))
                        }),
                        Parent = HueBar
                    })
                end
                
                local HueCursor = Create("Frame", {
                    Name = "Cursor",
                    Size = UDim2.new(1, 4, 0, 4),
                    AnchorPoint = Vector2.new(0.5, 0.5),
                    Position = UDim2.new(0.5, 0, h, 0),
                    BackgroundColor3 = Color3.new(1, 1, 1),
                    ZIndex = 32,
                    BorderSizePixel = 0,
                    Parent = HueBar
                })
                
                if HueCursor then
                    AddCorner(HueCursor, 2)
                    AddStroke(HueCursor, Color3.new(0, 0, 0), 1)
                end
                
                local function UpdateColor()
                    color = Color3.fromHSV(h, s, v)
                    if ColorBtn then ColorBtn.BackgroundColor3 = color end
                    if SVMap then SVMap.BackgroundColor3 = Color3.fromHSV(h, 1, 1) end
                    if flag then Library.Flags[flag] = color end
                    pcall(callback, color)
                end
                
                local draggingSV = false
                local draggingHue = false
                
                if SVMap then
                    SVMap.InputBegan:Connect(function(input)
                        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                            draggingSV = true
                        end
                    end)
                end
                
                if HueBar then
                    HueBar.InputBegan:Connect(function(input)
                        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                            draggingHue = true
                        end
                    end)
                end
                
                UserInputService.InputChanged:Connect(function(input)
                    if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
                        if draggingSV and SVMap then
                            local rx = math.clamp((input.Position.X - SVMap.AbsolutePosition.X) / SVMap.AbsoluteSize.X, 0, 1)
                            local ry = math.clamp((input.Position.Y - SVMap.AbsolutePosition.Y) / SVMap.AbsoluteSize.Y, 0, 1)
                            s = rx
                            v = 1 - ry
                            if SVCursor then SVCursor.Position = UDim2.new(s, 0, 1 - v, 0) end
                            UpdateColor()
                        elseif draggingHue and HueBar then
                            local ry = math.clamp((input.Position.Y - HueBar.AbsolutePosition.Y) / HueBar.AbsoluteSize.Y, 0, 1)
                            h = ry
                            if HueCursor then HueCursor.Position = UDim2.new(0.5, 0, h, 0) end
                            UpdateColor()
                        end
                    end
                end)
                
                UserInputService.InputEnded:Connect(function(input)
                    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                        draggingSV = false
                        draggingHue = false
                    end
                end)
                
                if ColorBtn then
                    ColorBtn.MouseButton1Click:Connect(function()
                        open = not open
                        if open then
                            if Picker then Picker.Visible = true end
                            Tween(Picker, 0.2, {Size = UDim2.new(1, 0, 0, 110)})
                            ColorFrame.Size = UDim2.new(1, 0, 0, 146)
                        else
                            Tween(Picker, 0.2, {Size = UDim2.new(1, 0, 0, 0)})
                            task.delay(0.2, function()
                                if Picker then Picker.Visible = false end
                            end)
                            ColorFrame.Size = UDim2.new(1, 0, 0, 32)
                        end
                    end)
                end
                
                if flag then Library.Flags[flag] = color end
                
                local obj = {}
                function obj:Set(col)
                    h, s, v = col:ToHSV()
                    if SVCursor then SVCursor.Position = UDim2.new(s, 0, 1 - v, 0) end
                    if HueCursor then HueCursor.Position = UDim2.new(0.5, 0, h, 0) end
                    UpdateColor()
                end
                function obj:Get()
                    return color
                end
                return obj
            end
            
            return SectionObj
        end
        
        return Tab
    end

    
    return Window
end

return Library
