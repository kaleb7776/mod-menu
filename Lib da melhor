if Logo then
    AddCorner(Logo, 6)

    local imagePath = "classic_hub_logo.png"
    local imageUrl = "https://i.postimg.cc/WbFVrmNQ/logo1-removebg-preview-(1).png"
    local imagemCarregada = false

    -- Fallback (letra)
    local function UseFallback()
        if imagemCarregada then return end
        Logo.BackgroundTransparency = 0
        Create("TextLabel", {
            Size = UDim2.new(1, 0, 1, 0),
            BackgroundTransparency = 1,
            Text = string.sub(hubName, 1, 1):upper(),
            TextColor3 = Color3.new(1, 1, 1),
            TextSize = 14,
            Font = Enum.Font.SourceSansBold,
            Parent = Logo
        })
        Library:Notify("Logo", "Imagem não encontrada. Usando letra.", 3, "Warning")
    end

    -- Aplica a imagem já baixada
    local function AplicarImagem()
        if imagemCarregada then return true end
        if not isfile(imagePath) then
            Library:Notify("Logo", "Arquivo não encontrado.", 2, "Error")
            return false
        end

        -- Tenta getcustomasset (estilo loader)
        if getcustomasset then
            local assetId = getcustomasset(imagePath)
            if assetId and assetId ~= "" then
                Logo.BackgroundTransparency = 1
                Create("ImageLabel", {
                    Size = UDim2.new(1, 0, 1, 0),
                    BackgroundTransparency = 1,
                    Image = assetId,
                    ScaleType = Enum.ScaleType.Fit,
                    Parent = Logo
                })
                imagemCarregada = true
                Library:Notify("Logo", "Carregado via getcustomasset ✅", 2, "Success")
                return true
            end
        end

        -- Fallback: rbxasset://
        Logo.BackgroundTransparency = 1
        Create("ImageLabel", {
            Size = UDim2.new(1, 0, 1, 0),
            BackgroundTransparency = 1,
            Image = "rbxasset://" .. imagePath,
            ScaleType = Enum.ScaleType.Fit,
            Parent = Logo
        })
        imagemCarregada = true
        Library:Notify("Logo", "Carregado via rbxasset://", 2, "Info")
        return true
    end

    -- Baixa a imagem (se não existir) e espera
    local function BaixarEExecutar()
        if isfile(imagePath) then
            AplicarImagem()
            return
        end

        Library:Notify("Logo", "Baixando imagem...", 2, "Info")
        local success, data = pcall(game.HttpGet, game, imageUrl)
        if success and data and #data > 100 then
            local writeOk = pcall(writefile, imagePath, data)
            if writeOk then
                Library:Notify("Logo", "Download concluído!", 2, "Success")
                AplicarImagem()
                return
            else
                Library:Notify("Logo", "Falha ao salvar arquivo.", 3, "Error")
            end
        else
            Library:Notify("Logo", "Falha no download.", 3, "Error")
        end
        UseFallback()
    end

    -- Executa o download (síncrono)
    BaixarEExecutar()

    -- Segunda tentativa após 1 segundo (caso o arquivo demore a ser escrito)
    task.delay(1.5, function()
        if not imagemCarregada then
            if AplicarImagem() then
                Library:Notify("Logo", "Carregado na segunda tentativa ✅", 2, "Success")
            else
                UseFallback()
            end
        end
    end)
end
