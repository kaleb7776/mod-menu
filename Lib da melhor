    -- Tab System
    local Tabs = {}
    local CurrentTab = nil
    local Window = {}
    
    function Window:AddTab(name, icon)
        name = name or "Tab"
        icon = icon or ""
        
        if not TabHolder then return nil end
        
        local TabBtn = Create("TextButton", {
            Name = name,
            Size = UDim2.new(1, 0, 0, 35),
            BackgroundColor3 = Theme.Sidebar,
            BackgroundTransparency = 1,
            Text = "",
            AutoButtonColor = false,
            Parent = TabHolder
        })
        
        if not TabBtn then return nil end
        
        AddCorner(TabBtn, 6)
        
        local tabIconLabel = nil
        if icon ~= "" then
            tabIconLabel = Create("TextLabel", {
                Name = "Icon",
                Size = UDim2.new(0, 25, 1, 0),
                Position = UDim2.new(0, 5, 0, 0),
                BackgroundTransparency = 1,
                Text = icon,
                TextColor3 = Theme.TextDark,
                TextSize = 14,
                Font = Enum.Font.Gotham,
                Parent = TabBtn
            })
        end
        
        local TabLabel = Create("TextLabel", {
            Name = "Label",
            Size = UDim2.new(1, icon ~= "" and -35 or -15, 1, 0),
            Position = UDim2.new(0, icon ~= "" and 30 or 10, 0, 0),
            BackgroundTransparency = 1,
            Text = name,
            TextColor3 = Theme.TextDark,
            TextSize = 13,
            Font = Enum.Font.Gotham,
            TextXAlignment = Enum.TextXAlignment.Left,
            Parent = TabBtn
        })
        
        if not ContentArea then return nil end
        
        local TabPage = Create("ScrollingFrame", {
            Name = name .. "Page",
            Size = UDim2.new(1, 0, 1, 0),
            BackgroundTransparency = 1,
            ScrollBarThickness = 3,
            ScrollBarImageColor3 = Theme.Accent,
            BorderSizePixel = 0,
            CanvasSize = UDim2.new(0, 0, 0, 0),
            Visible = false,
            Parent = ContentArea
        })
        
        if not TabPage then return nil end
        
        local PageLayout = Create("UIListLayout", {
            Padding = UDim.new(0, 8),
            SortOrder = Enum.SortOrder.LayoutOrder,
            Parent = TabPage
        })
        
        Create("UIPadding", {
            PaddingTop = UDim.new(0, 5),
            PaddingLeft = UDim.new(0, 5),
            PaddingRight = UDim.new(0, 5),
            PaddingBottom = UDim.new(0, 5),
            Parent = TabPage
        })
        
        if PageLayout then
            PageLayout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
                TabPage.CanvasSize = UDim2.new(0, 0, 0, PageLayout.AbsoluteContentSize.Y + 20)
            end)
        end
        
        Tabs[name] = {
            Button = TabBtn,
            Page = TabPage,
            Label = TabLabel,
            Icon = tabIconLabel
        }
        
        -- First tab is selected
        if CurrentTab == nil then
            CurrentTab = name
            TabPage.Visible = true
            TabBtn.BackgroundTransparency = 0
            TabBtn.BackgroundColor3 = Theme.Accent
            if TabLabel then TabLabel.TextColor3 = Color3.new(1, 1, 1) end
            if tabIconLabel then tabIconLabel.TextColor3 = Color3.new(1, 1, 1) end
        end
        
        TabBtn.MouseButton1Click:Connect(function()
            if CurrentTab == name then return end
            
            -- Deselect old tab
            if CurrentTab and Tabs[CurrentTab] then
                local oldTab = Tabs[CurrentTab]
                if oldTab.Page then oldTab.Page.Visible = false end
                if oldTab.Button then Tween(oldTab.Button, 0.2, {BackgroundTransparency = 1}) end
                if oldTab.Label then Tween(oldTab.Label, 0.2, {TextColor3 = Theme.TextDark}) end
                if oldTab.Icon then Tween(oldTab.Icon, 0.2, {TextColor3 = Theme.TextDark}) end
            end
            
            -- Select new tab
            CurrentTab = name
            TabPage.Visible = true
            Tween(TabBtn, 0.2, {BackgroundTransparency = 0, BackgroundColor3 = Theme.Accent})
            if TabLabel then Tween(TabLabel, 0.2, {TextColor3 = Color3.new(1, 1, 1)}) end
            if tabIconLabel then Tween(tabIconLabel, 0.2, {TextColor3 = Color3.new(1, 1, 1)}) end
        end)
        
        TabBtn.MouseEnter:Connect(function()
            if CurrentTab ~= name then
                Tween(TabBtn, 0.15, {BackgroundTransparency = 0.5, BackgroundColor3 = Theme.Element})
            end
        end)
        
        TabBtn.MouseLeave:Connect(function()
            if CurrentTab ~= name then
                Tween(TabBtn, 0.15, {BackgroundTransparency = 1})
            end
        end)
        
