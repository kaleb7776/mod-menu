                    })
                end
                
                local function RefreshOptions()
                    if not listScroll then return end
                    for _, child in pairs(listScroll:GetChildren()) do
                        if child:IsA("TextButton") then
                            child:Destroy()
                        end
                    end
                    
                    for index, option in ipairs(options) do
                        local optionButton = Create("TextButton", {
                            Name = "Option" .. index,
                            Size = UDim2.new(1, 0, 0, 26),
                            BackgroundColor3 = Theme.Element,
                            BackgroundTransparency = 1,
                            Text = option,
                            TextColor3 = (option == selected) and Theme.Accent or Theme.TextDark,
                            TextSize = 12,
                            Font = Enum.Font.Gotham,
                            ZIndex = 52,
                            Parent = listScroll
                        })
                        if optionButton then
                            AddCorner(optionButton, 4)
                            optionButton.MouseEnter:Connect(function()
                                Tween(optionButton, 0.1, {BackgroundTransparency = 0})
                            end)
                            optionButton.MouseLeave:Connect(function()
                                Tween(optionButton, 0.1, {BackgroundTransparency = 1})
                            end)
                            optionButton.MouseButton1Click:Connect(function()
                                selected = option
                                if selectedLabel then selectedLabel.Text = option end
                                if flag then Library.Flags[flag] = selected end
                                pcall(callback, selected)
                                isOpen = false
                                Tween(dropdownList, 0.2, {Size = UDim2.new(1, 0, 0, 0)})
                                Tween(arrowLabel, 0.2, {Rotation = 0})
                                task.delay(0.2, function()
                                    if dropdownList then dropdownList.Visible = false end
                                end)
                                dropdownFrame.Size = UDim2.new(1, 0, 0, 50)
                                RefreshOptions()
                            end)
                        end
                    end
                    
                    if listScroll then
                        listScroll.CanvasSize = UDim2.new(0, 0, 0, #options * 28)
                    end
                end
                
                RefreshOptions()
                
                dropdownButton.MouseButton1Click:Connect(function()
                    isOpen = not isOpen
                    if isOpen then
                        if dropdownList then dropdownList.Visible = true end
                        local height = math.min(#options * 28 + 6, 130)
                        Tween(dropdownList, 0.2, {Size = UDim2.new(1, 0, 0, height)})
                        Tween(arrowLabel, 0.2, {Rotation = 180})
                        dropdownFrame.Size = UDim2.new(1, 0, 0, 54 + height)
                    else
                        Tween(dropdownList, 0.2, {Size = UDim2.new(1, 0, 0, 0)})
                        Tween(arrowLabel, 0.2, {Rotation = 0})
                        task.delay(0.2, function()
                            if dropdownList then dropdownList.Visible = false end
                        end)
                        dropdownFrame.Size = UDim2.new(1, 0, 0, 50)
                    end
                end)
                
                dropdownButton.MouseEnter:Connect(function()
                    Tween(dropdownButton, 0.15, {BackgroundColor3 = Theme.ElementHover})
                end)
                dropdownButton.MouseLeave:Connect(function()
                    Tween(dropdownButton, 0.15, {BackgroundColor3 = Theme.Element})
                end)
                
                if flag then Library.Flags[flag] = selected end
                
                local object = {}
                function object:Set(value)
                    selected = value
                    if selectedLabel then selectedLabel.Text = value end
                    if flag then Library.Flags[flag] = selected end
                    RefreshOptions()
                end
                function object:Get()
                    return selected
                end
                function object:Refresh(newOptions)
                    options = newOptions
                    RefreshOptions()
                end
                return object
            end
            
