            -- TOGGLE
            function SectionObj:AddToggle(text, default, flag, callback)
                text = text or "Toggle"
                default = default or false
                callback = callback or function() end
                
                local toggled = default
                
                local Toggle = Create("TextButton", {
                    Name = "Toggle",
                    Size = UDim2.new(1, 0, 0, 32),
                    BackgroundTransparency = 1,
                    Text = "",
                    AutoButtonColor = false,
                    Parent = Content
                })
                
                if not Toggle then return nil end
                
                Create("TextLabel", {
                    Name = "Label",
                    Size = UDim2.new(1, -55, 1, 0),
                    BackgroundTransparency = 1,
                    Text = text,
                    TextColor3 = Theme.Text,
                    TextSize = 12,
                    Font = Enum.Font.Gotham,
                    TextXAlignment = Enum.TextXAlignment.Left,
                    Parent = Toggle
                })
                
                local ToggleBg = Create("Frame", {
                    Name = "Background",
                    Size = UDim2.new(0, 44, 0, 22),
                    Position = UDim2.new(1, -46, 0.5, -11),
                    BackgroundColor3 = Theme.Toggle,
                    BorderSizePixel = 0,
                    Parent = Toggle
                })
                
                if not ToggleBg then return nil end
                
                AddCorner(ToggleBg, 11)
                
                local ToggleCircle = Create("Frame", {
                    Name = "Circle",
                    Size = UDim2.new(0, 18, 0, 18),
                    Position = UDim2.new(0, 2, 0.5, -9),
                    BackgroundColor3 = Theme.TextDark,
                    BorderSizePixel = 0,
                    Parent = ToggleBg
                })
                
                if ToggleCircle then
                    AddCorner(ToggleCircle, 9)
                end
                
                local function UpdateToggle(state)
                    toggled = state
                    if flag then Library.Flags[flag] = toggled end
                    
                    if toggled then
                        Tween(ToggleBg, 0.2, {BackgroundColor3 = Theme.ToggleOn})
                        Tween(ToggleCircle, 0.2, {
                            Position = UDim2.new(1, -20, 0.5, -9),
                            BackgroundColor3 = Color3.new(1, 1, 1)
                        })
                    else
                        Tween(ToggleBg, 0.2, {BackgroundColor3 = Theme.Toggle})
                        Tween(ToggleCircle, 0.2, {
                            Position = UDim2.new(0, 2, 0.5, -9),
                            BackgroundColor3 = Theme.TextDark
                        })
                    end
                    
                    pcall(callback, toggled)
                end
                
                Toggle.MouseButton1Click:Connect(function()
                    UpdateToggle(not toggled)
                end)
                
                if flag then Library.Flags[flag] = toggled end
                if default then
                    task.defer(function()
                        UpdateToggle(true)
                    end)
                end
                
                local obj = {}
                function obj:Set(state)
                    UpdateToggle(state)
                end
                function obj:Get()
                    return toggled
                end
                return obj
            end
            
            -- SLIDER
            function SectionObj:AddSlider(text, min, max, default, flag, callback)
                text = text or "Slider"
                min = min or 0
                max = max or 100
                default = default or min
                callback = callback or function() end
                
                local value = math.clamp(default, min, max)
                
                local SliderFrame = Create("Frame", {
                    Name = "Slider",
                    Size = UDim2.new(1, 0, 0, 42),
                    BackgroundTransparency = 1,
                    Parent = Content
                })
                
                if not SliderFrame then return nil end
                
                Create("TextLabel", {
                    Name = "Label",
                    Size = UDim2.new(0.6, 0, 0, 18),
                    BackgroundTransparency = 1,
                    Text = text,
                    TextColor3 = Theme.Text,
                    TextSize = 12,
                    Font = Enum.Font.Gotham,
                    TextXAlignment = Enum.TextXAlignment.Left,
                    Parent = SliderFrame
                })
                
                local ValueLabel = Create("TextLabel", {
                    Name = "Value",
                    Size = UDim2.new(0.4, 0, 0, 18),
                    Position = UDim2.new(0.6, 0, 0, 0),
                    BackgroundTransparency = 1,
                    Text = tostring(value),
                    TextColor3 = Theme.Accent,
                    TextSize = 12,
                    Font = Enum.Font.GothamBold,
                    TextXAlignment = Enum.TextXAlignment.Right,
                    Parent = SliderFrame
                })
                
                local SliderBg = Create("Frame", {
                    Name = "Background",
                    Size = UDim2.new(1, 0, 0, 12),
                    Position = UDim2.new(0, 0, 0, 24),
                    BackgroundColor3 = Theme.SliderBg,
                    BorderSizePixel = 0,
                    Parent = SliderFrame
                })
                
                if not SliderBg then return nil end
                
                AddCorner(SliderBg, 6)
                
                local ratio = (value - min) / (max - min)
                local SliderFill = Create("Frame", {
                    Name = "Fill",
                    Size = UDim2.new(ratio, 0, 1, 0),
                    BackgroundColor3 = Theme.Accent,
                    BorderSizePixel = 0,
                    Parent = SliderBg
                })
                
                if SliderFill then
                    AddCorner(SliderFill, 6)
                end
                
                local SliderBtn = Create("TextButton", {
                    Name = "Button",
                    Size = UDim2.new(1, 0, 1, 0),
                    BackgroundTransparency = 1,
                    Text = "",
                    Parent = SliderBg
                })
                
                local function SetValue(val)
                    value = math.clamp(math.floor(val + 0.5), min, max)
                    local newRatio = (value - min) / (max - min)
                    Tween(SliderFill, 0.1, {Size = UDim2.new(newRatio, 0, 1, 0)})
                    if ValueLabel then ValueLabel.Text = tostring(value) end
                    if flag then Library.Flags[flag] = value end
                    pcall(callback, value)
                end
                
                local dragging = false
                
                local function UpdateSlider(input)
                    if not SliderBg then return end
                    local pos = math.clamp((input.Position.X - SliderBg.AbsolutePosition.X) / SliderBg.AbsoluteSize.X, 0, 1)
                    SetValue(min + pos * (max - min))
                end
                
                if SliderBtn then
                    SliderBtn.InputBegan:Connect(function(input)
                        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                            dragging = true
                            UpdateSlider(input)
                        end
                    end)
                end
                
                UserInputService.InputChanged:Connect(function(input)
                    if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
                        UpdateSlider(input)
                    end
                end)
                
                UserInputService.InputEnded:Connect(function(input)
                    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                        dragging = false
                    end
                end)
                
                if flag then Library.Flags[flag] = value end
                
                local obj = {}
                function obj:Set(val)
                    SetValue(val)
                end
                function obj:Get()
                    return value
                end
                return obj
            end
            
