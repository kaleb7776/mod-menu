                    BackgroundColor3 = Theme.Accent,
                    BorderSizePixel = 0,
                    Parent = sliderBackground
                })
                if sliderFill then AddCorner(sliderFill, 6) end
                
                local sliderButton = Create("TextButton", {
                    Name = "Button",
                    Size = UDim2.new(1, 0, 1, 0),
                    BackgroundTransparency = 1,
                    Text = "",
                    Parent = sliderBackground
                })
                
                local function SetValue(newValue)
                    value = math.clamp(math.floor(newValue + 0.5), minimum, maximum)
                    local newRatio = (value - minimum) / (maximum - minimum)
                    Tween(sliderFill, 0.1, {Size = UDim2.new(newRatio, 0, 1, 0)})
                    if valueLabel then valueLabel.Text = tostring(value) end
                    if flag then Library.Flags[flag] = value end
                    pcall(callback, value)
                end
                
                local isDragging = false
                local function UpdateSlider(input)
                    if not sliderBackground then return end
                    local position = math.clamp((input.Position.X - sliderBackground.AbsolutePosition.X) / sliderBackground.AbsoluteSize.X, 0, 1)
                    SetValue(minimum + position * (maximum - minimum))
                end
                
                if sliderButton then
                    sliderButton.InputBegan:Connect(function(input)
                        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                            isDragging = true
                            UpdateSlider(input)
                        end
                    end)
                end
                
                UserInputService.InputChanged:Connect(function(input)
                    if isDragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
                        UpdateSlider(input)
                    end
                end)
                
                UserInputService.InputEnded:Connect(function(input)
                    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                        isDragging = false
                    end
                end)
                
                if flag then Library.Flags[flag] = value end
                
                local object = {}
                function object:Set(newValue)
                    SetValue(newValue)
                end
                function object:Get()
                    return value
                end
                return object
            end
            
