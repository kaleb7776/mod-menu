function Library:Notify(title, text, duration, notificationType)
    if not NotificationHolder then return end
    
    duration = duration or 3
    notificationType = notificationType or "Info"
    
    local colors = {
        Info = Theme.Accent,
        Success = Theme.Success,
        Warning = Theme.Warning,
        Error = Theme.Error
    }
    
    local notification = Create("Frame", {
        Size = UDim2.new(1, 0, 0, 70),
        BackgroundColor3 = Theme.Section,
        Parent = NotificationHolder
    })
    if not notification then return end
    
    AddCorner(notification, 8)
    AddStroke(notification, Theme.Border)
    
    local accentBar = Create("Frame", {
        Size = UDim2.new(0, 4, 1, -10),
        Position = UDim2.new(0, 5, 0, 5),
        BackgroundColor3 = colors[notificationType] or Theme.Accent,
        BorderSizePixel = 0,
        Parent = notification
    })
    AddCorner(accentBar, 2)
    
    Create("TextLabel", {
        Size = UDim2.new(1, -50, 0, 22),
        Position = UDim2.new(0, 18, 0, 8),
        BackgroundTransparency = 1,
        Text = title or "Notificação",
        TextColor3 = Theme.Text,
        TextSize = 14,
        Font = Enum.Font.GothamBold,
        TextXAlignment = Enum.TextXAlignment.Left,
        Parent = notification
    })
    
    Create("TextLabel", {
        Size = UDim2.new(1, -25, 0, 32),
        Position = UDim2.new(0, 18, 0, 30),
        BackgroundTransparency = 1,
        Text = text or "",
        TextColor3 = Theme.TextDark,
        TextSize = 12,
        Font = Enum.Font.Gotham,
        TextXAlignment = Enum.TextXAlignment.Left,
        TextYAlignment = Enum.TextYAlignment.Top,
        TextWrapped = true,
        Parent = notification
    })
    
    local progressBar = Create("Frame", {
        Size = UDim2.new(1, 0, 0, 3),
        Position = UDim2.new(0, 0, 1, -3),
        BackgroundColor3 = colors[notificationType] or Theme.Accent,
        BorderSizePixel = 0,
        Parent = notification
    })
    
    notification.Position = UDim2.new(1, 20, 0, 0)
    Tween(notification, 0.3, {Position = UDim2.new(0, 0, 0, 0)})
    
    if progressBar then
        Tween(progressBar, duration, {Size = UDim2.new(0, 0, 0, 3)})
    end
    
    task.delay(duration, function()
        if notification and notification.Parent then
            Tween(notification, 0.3, {Position = UDim2.new(1, 20, 0, 0)})
            task.wait(0.35)
            if notification and notification.Parent then
                notification:Destroy()
            end
        end
    end)
end

