                            end)
                            colorFrame.Size = UDim2.new(1, 0, 0, 32)
                        end
                    end)
                end
                
                if flag then Library.Flags[flag] = color end
                
                local object = {}
                function object:Set(newColor)
                    hue, saturation, value = newColor:ToHSV()
                    if saturationValueCursor then saturationValueCursor.Position = UDim2.new(saturation, 0, 1 - value, 0) end
                    if hueCursor then hueCursor.Position = UDim2.new(0.5, 0, hue, 0) end
                    UpdateColor()
                end
                function object:Get()
                    return color
                end
                return object
            end
            
            return sectionObject
        end
        
        return tabObject
    end
    
    return windowObject
