                    Position = UDim2.new(0.5, 0, hue, 0),
                    BackgroundColor3 = Color3.new(1, 1, 1),
                    ZIndex = 32,
                    BorderSizePixel = 0,
                    Parent = hueBar
                })
                if hueCursor then
                    AddCorner(hueCursor, 2)
                    AddStroke(hueCursor, Color3.new(0, 0, 0), 1)
                end
                
                local function UpdateColor()
                    color = Color3.fromHSV(hue, saturation, value)
                    if colorButton then colorButton.BackgroundColor3 = color end
                    if saturationValueMap then saturationValueMap.BackgroundColor3 = Color3.fromHSV(hue, 1, 1) end
                    if flag then Library.Flags[flag] = color end
                    pcall(callback, color)
                end
                
                local isDraggingSaturation = false
                local isDraggingHue = false
                
                if saturationValueMap then
                    saturationValueMap.InputBegan:Connect(function(input)
                        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                            isDraggingSaturation = true
                        end
                    end)
                end
                
                if hueBar then
                    hueBar.InputBegan:Connect(function(input)
                        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                            isDraggingHue = true
                        end
                    end)
                end
                
                UserInputService.InputChanged:Connect(function(input)
                    if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
                        if isDraggingSaturation and saturationValueMap then
                            local relativeX = math.clamp((input.Position.X - saturationValueMap.AbsolutePosition.X) / saturationValueMap.AbsoluteSize.X, 0, 1)
                            local relativeY = math.clamp((input.Position.Y - saturationValueMap.AbsolutePosition.Y) / saturationValueMap.AbsoluteSize.Y, 0, 1)
                            saturation = relativeX
                            value = 1 - relativeY
                            if saturationValueCursor then saturationValueCursor.Position = UDim2.new(saturation, 0, 1 - value, 0) end
                            UpdateColor()
                        elseif isDraggingHue and hueBar then
                            local relativeY = math.clamp((input.Position.Y - hueBar.AbsolutePosition.Y) / hueBar.AbsoluteSize.Y, 0, 1)
                            hue = relativeY
                            if hueCursor then hueCursor.Position = UDim2.new(0.5, 0, hue, 0) end
                            UpdateColor()
                        end
                    end
                end)
                
                UserInputService.InputEnded:Connect(function(input)
                    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                        isDraggingSaturation = false
                        isDraggingHue = false
                    end
                end)
                
                if colorButton then
                    colorButton.MouseButton1Click:Connect(function()
                        isOpen = not isOpen
                        if isOpen then
                            if pickerFrame then pickerFrame.Visible = true end
                            Tween(pickerFrame, 0.2, {Size = UDim2.new(1, 0, 0, 110)})
                            colorFrame.Size = UDim2.new(1, 0, 0, 146)
