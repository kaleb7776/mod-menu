        task.spawn(function()
            pcall(function()
                local frameCounter = 0
                local timeAccumulator = 0
                local framesPerSecond = 0
                local pingInMilliseconds = 0
                
                local function GetPing()
                    local stats = game:GetService("Stats")
                    local network = stats:FindFirstChild("Network")
                    if network then
                        local pingValue = network:FindFirstChild("Ping")
                        if pingValue and pingValue.Value then
                            return math.floor(pingValue.Value * 1000)
                        end
                    end
                    local performance = stats:FindFirstChild("PerformanceStats")
                    if performance then
                        local pingValue = performance:FindFirstChild("Ping")
                        if pingValue and pingValue.Value then
                            return math.floor(pingValue.Value * 1000)
                        end
                    end
                    for _, child in ipairs(stats:GetDescendants()) do
                        if child.Name:lower():find("ping") and child:IsA("NumberValue") then
                            return math.floor(child.Value * 1000)
                        end
                    end
                    return 0
                end
                
                local function GetMemoryUsage()
                    local stats = game:GetService("Stats")
                    local memory = stats:FindFirstChild("Memory")
                    if memory then
                        local memoryInMb = memory:FindFirstChild("MemoryUsedMb")
                        if memoryInMb and memoryInMb.Value then
                            return memoryInMb.Value
                        end
                    end
                    return 0
                end
                
                RunService.RenderStepped:Connect(function(deltaTime)
                    pcall(function()
                        frameCounter = frameCounter + 1
                        timeAccumulator = timeAccumulator + deltaTime
                        
                        if timeAccumulator >= 0.5 then
                            framesPerSecond = math.floor(frameCounter / timeAccumulator)
                            frameCounter = 0
                            timeAccumulator = 0
                            pingInMilliseconds = GetPing()
                        end
                        
                        statusLabel.Text = string.format("FPS: %d Ping: %dms", framesPerSecond, pingInMilliseconds)
                        
                        local currentTime = os.date("*t")
                        local timeString = string.format("%02d:%02d:%02d", currentTime.hour, currentTime.min, currentTime.sec)
                        local memory = GetMemoryUsage()
                        local memoryString = (memory > 0) and string.format("%.1f MB", memory) or "-- MB"
                        extraStatusLabel.Text = string.format("%s • %s", timeString, memoryString)
                    end)
                end)
