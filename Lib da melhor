                    Text = "▼",
                    TextColor3 = Theme.TextDark,
                    TextSize = 10,
                    Font = Enum.Font.GothamBold,
                    Parent = DropBtn
                })
                
                local DropList = Create("Frame", {
                    Name = "List",
                    Size = UDim2.new(1, 0, 0, 0),
                    Position = UDim2.new(0, 0, 0, 52),
                    BackgroundColor3 = Theme.Section,
                    ClipsDescendants = true,
                    Visible = false,
                    ZIndex = 50,
                    BorderSizePixel = 0,
                    Parent = DropFrame
                })
                
                if DropList then
                    AddCorner(DropList, 6)
                    AddStroke(DropList, Theme.Border)
                end
                
                local ListScroll = Create("ScrollingFrame", {
                    Name = "Scroll",
                    Size = UDim2.new(1, -6, 1, -6),
                    Position = UDim2.new(0, 3, 0, 3),
                    BackgroundTransparency = 1,
                    ScrollBarThickness = 2,
                    ScrollBarImageColor3 = Theme.Accent,
                    BorderSizePixel = 0,
                    ZIndex = 51,
                    CanvasSize = UDim2.new(0, 0, 0, 0),
                    Parent = DropList
                })
                
                local ListLayout = nil
                if ListScroll then
                    ListLayout = Create("UIListLayout", {
                        Padding = UDim.new(0, 2),
                        SortOrder = Enum.SortOrder.LayoutOrder,
                        Parent = ListScroll
                    })
                end
                
                local function RefreshOptions()
                    if not ListScroll then return end
                    
                    for _, v in pairs(ListScroll:GetChildren()) do
                        if v:IsA("TextButton") then
                            v:Destroy()
                        end
                    end
                    
                    for i, opt in ipairs(options) do
                        local OptBtn = Create("TextButton", {
                            Name = "Option" .. i,
                            Size = UDim2.new(1, 0, 0, 26),
                            BackgroundColor3 = Theme.Element,
                            BackgroundTransparency = 1,
                            Text = opt,
                            TextColor3 = (opt == selected) and Theme.Accent or Theme.TextDark,
                            TextSize = 12,
                            Font = Enum.Font.Gotham,
                            ZIndex = 52,
                            Parent = ListScroll
                        })
                        
                        if OptBtn then
                            AddCorner(OptBtn, 4)
                            
                            OptBtn.MouseEnter:Connect(function()
                                Tween(OptBtn, 0.1, {BackgroundTransparency = 0})
                            end)
                            
                            OptBtn.MouseLeave:Connect(function()
                                Tween(OptBtn, 0.1, {BackgroundTransparency = 1})
                            end)
                            
                            OptBtn.MouseButton1Click:Connect(function()
                                selected = opt
                                if SelectedLabel then SelectedLabel.Text = opt end
                                if flag then Library.Flags[flag] = selected end
                                pcall(callback, selected)
                                
                                -- Close
                                open = false
                                Tween(DropList, 0.2, {Size = UDim2.new(1, 0, 0, 0)})
                                Tween(Arrow, 0.2, {Rotation = 0})
                                task.delay(0.2, function()
                                    if DropList then DropList.Visible = false end
                                end)
                                DropFrame.Size = UDim2.new(1, 0, 0, 50)
                                
                                RefreshOptions()
                            end)
                        end
                    end
                    
                    if ListScroll then
                        ListScroll.CanvasSize = UDim2.new(0, 0, 0, #options * 28)
                    end
                end
                
                RefreshOptions()
                
                DropBtn.MouseButton1Click:Connect(function()
                    open = not open
                    
                    if open then
                        if DropList then DropList.Visible = true end
                        local h = math.min(#options * 28 + 6, 130)
                        Tween(DropList, 0.2, {Size = UDim2.new(1, 0, 0, h)})
                        Tween(Arrow, 0.2, {Rotation = 180})
                        DropFrame.Size = UDim2.new(1, 0, 0, 54 + h)
                    else
                        Tween(DropList, 0.2, {Size = UDim2.new(1, 0, 0, 0)})
                        Tween(Arrow, 0.2, {Rotation = 0})
                        task.delay(0.2, function()
                            if DropList then DropList.Visible = false end
                        end)
                        DropFrame.Size = UDim2.new(1, 0, 0, 50)
                    end
                end)
                
                DropBtn.MouseEnter:Connect(function()
                    Tween(DropBtn, 0.15, {BackgroundColor3 = Theme.ElementHover})
                end)
                
                DropBtn.MouseLeave:Connect(function()
                    Tween(DropBtn, 0.15, {BackgroundColor3 = Theme.Element})
                end)
                
                if flag then Library.Flags[flag] = selected end
                
                local obj = {}
                function obj:Set(val)
                    selected = val
                    if SelectedLabel then SelectedLabel.Text = val end
                    if flag then Library.Flags[flag] = selected end
                    RefreshOptions()
                end
                function obj:Get()
                    return selected
                end
                function obj:Refresh(newOpts)
                    options = newOpts
                    RefreshOptions()
                end
                return obj
            end
            
