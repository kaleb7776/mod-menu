                        Tween(keyLabel, 0.15, {BackgroundColor3 = Theme.Accent})
                        keyLabel.TextColor3 = Color3.new(1, 1, 1)
                    end
                    
                    local connection
                    connection = UserInputService.InputBegan:Connect(function(input)
                        if input.UserInputType == Enum.UserInputType.Keyboard then
                            key = input.KeyCode
                            if keyLabel then
                                keyLabel.Text = key.Name
                                Tween(keyLabel, 0.15, {BackgroundColor3 = Theme.SliderBg})
                                keyLabel.TextColor3 = Theme.Accent
                            end
                            if flag then Library.Flags[flag] = key end
                            isListening = false
                            connection:Disconnect()
                        end
                    end)
                end)
                
                keybindFrame.MouseEnter:Connect(function()
                    Tween(keybindFrame, 0.15, {BackgroundColor3 = Theme.ElementHover})
                end)
                keybindFrame.MouseLeave:Connect(function()
                    Tween(keybindFrame, 0.15, {BackgroundColor3 = Theme.Element})
                end)
                
                UserInputService.InputBegan:Connect(function(input, gameProcessed)
                    if gameProcessed or isListening then return end
                    if input.KeyCode == key then
                        pcall(callback)
                    end
                end)
                
                if flag then Library.Flags[flag] = key end
                
                local object = {}
                function object:Set(newKey)
                    key = newKey
                    if keyLabel then
                        keyLabel.Text = (key.Name == "None") and "..." or key.Name
                    end
                    if flag then Library.Flags[flag] = key end
                end
                function object:Get()
                    return key
                end
                return object
            end
            
